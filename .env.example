# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL="https://anon.li"

# ===================
# Database
# ===================
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ===================
# Authentication
# ===================
AUTH_SECRET="openssl-rand-base64-32"

# Turnstile (Bot Protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# OAuth Providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ===================
# Email (Resend)
# ===================
AUTH_RESEND_KEY=""

# ===================
# Stripe Payments
# ===================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs - Bundle Plans
STRIPE_BUNDLE_PLUS_MONTHLY_PRICE_ID=""
STRIPE_BUNDLE_PLUS_YEARLY_PRICE_ID=""
STRIPE_BUNDLE_PRO_MONTHLY_PRICE_ID=""
STRIPE_BUNDLE_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Alias Plans
STRIPE_ALIAS_PLUS_MONTHLY_PRICE_ID=""
STRIPE_ALIAS_PLUS_YEARLY_PRICE_ID=""
STRIPE_ALIAS_PRO_MONTHLY_PRICE_ID=""
STRIPE_ALIAS_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Drop Plans
STRIPE_DROP_PLUS_MONTHLY_PRICE_ID=""
STRIPE_DROP_PLUS_YEARLY_PRICE_ID=""
STRIPE_DROP_PRO_MONTHLY_PRICE_ID=""
STRIPE_DROP_PRO_YEARLY_PRICE_ID=""

# ===================
# Cloudflare R2 Storage
# ===================
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT="" # https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=""
# Public custom domain for R2 bucket. Presigned download URLs are signed
# against this host so traffic bypasses our servers entirely. R2 has zero
# egress fees by default. Production: https://r2.anon.li
R2_PUBLIC_ENDPOINT="https://r2.anon.li"

# ===================
# Rate Limiting (Upstash)
# ===================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===================
# Cron Jobs
# ===================
CRON_SECRET="openssl-rand-base64-32"

# ===================
# Abuse Reporting
# ===================
IP_HASH_PEPPER="openssl-rand-base64-32"
REPORT_ENCRYPTION_KEY="openssl-rand-base64-32"

# ===================
# DKIM Key Encryption
# ===================
DKIM_ENCRYPTION_KEY="" # 64-char hex string. Encrypts DKIM private keys at rest.

# ===================
# Mail Server
# ===================
MAIL_API_SECRET="openssl-rand-base64-32"

# ===================
# NowPayments (optional crypto payments)
# ===================
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# ===================
# Logging
# ===================
STRUCTURED_LOGS="" # set to "true" for JSON structured logs

# ===================
# DKIM (alternative to database-stored keys)
# ===================
DKIM_KEY_PATH="" # file path to DKIM private key (optional)

# ===================
# Analytics (Umami)
# ===================
NEXT_PUBLIC_UMAMI_WEBSITE_ID="umami-website-id"
NEXT_PUBLIC_UMAMI_URL="https://cloud.umami.is/script.js"
