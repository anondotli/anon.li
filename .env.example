# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL="https://anon.li"

# ===================
# Database
# ===================
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ===================
# Authentication
# ===================
AUTH_SECRET="openssl-rand-base64-32"

# Turnstile (Bot Protection) — required; the captcha is always enforced.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# OAuth Providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ===================
# Email (Resend)
# ===================
AUTH_RESEND_KEY=""

# ===================
# Stripe Payments
# ===================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs - Bundle Plans
STRIPE_BUNDLE_PLUS_MONTHLY_PRICE_ID=""
STRIPE_BUNDLE_PLUS_YEARLY_PRICE_ID=""
STRIPE_BUNDLE_PRO_MONTHLY_PRICE_ID=""
STRIPE_BUNDLE_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Alias Plans
STRIPE_ALIAS_PLUS_MONTHLY_PRICE_ID=""
STRIPE_ALIAS_PLUS_YEARLY_PRICE_ID=""
STRIPE_ALIAS_PRO_MONTHLY_PRICE_ID=""
STRIPE_ALIAS_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Drop Plans
STRIPE_DROP_PLUS_MONTHLY_PRICE_ID=""
STRIPE_DROP_PLUS_YEARLY_PRICE_ID=""
STRIPE_DROP_PRO_MONTHLY_PRICE_ID=""
STRIPE_DROP_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Form Plans
STRIPE_FORM_PLUS_MONTHLY_PRICE_ID=""
STRIPE_FORM_PLUS_YEARLY_PRICE_ID=""
STRIPE_FORM_PRO_MONTHLY_PRICE_ID=""
STRIPE_FORM_PRO_YEARLY_PRICE_ID=""

# Stripe Price IDs - Business (Teams, per-seat)
STRIPE_BUSINESS_MONTHLY_PRICE_ID=""
STRIPE_BUSINESS_YEARLY_PRICE_ID=""

# ===================
# Cloudflare R2 Storage
# ===================
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT="" # https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=""
# Public custom domain for R2 bucket. Presigned download URLs are signed
# against this host so traffic bypasses our servers entirely. R2 has zero
# egress fees by default. Production: https://r2.anon.li
R2_PUBLIC_ENDPOINT="https://r2.anon.li"

# ===================
# Rate Limiting (Upstash) — required in all environments
# ===================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===================
# Cron Jobs
# ===================
CRON_SECRET="openssl-rand-base64-32"

# ===================
# Abuse Reporting
# ===================
IP_HASH_PEPPER="openssl-rand-base64-32"
REPORT_ENCRYPTION_KEY="" # required. 64-char hex string (32 bytes): openssl rand -hex 32

# ===================
# DKIM Key Encryption
# ===================
DKIM_ENCRYPTION_KEY="" # required. 64-char hex string. Encrypts DKIM private keys at rest.

# ===================
# NowPayments (optional crypto payments)
# ===================
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# ===================
# Analytics & Observability (PostHog, optional)
# ===================
# Project API key (public). Leave empty to disable analytics + error tracking.
NEXT_PUBLIC_POSTHOG_KEY=""
# Client ingestion host — defaults to the first-party reverse proxy at /ingest.
NEXT_PUBLIC_POSTHOG_HOST="/ingest"
# Server (posthog-node) host — the real PostHog region endpoint (EU).
POSTHOG_HOST="https://eu.i.posthog.com"
