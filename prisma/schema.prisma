datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id   String  @id @default(cuid())
  name String?

  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Resource Ownership
  aliases           Alias[]
  domains           Domain[]
  apiKeys           ApiKey[]
  recipients        Recipient[]
  drops             Drop[]
  security          UserSecurity?
  dropOwnerKeys     DropOwnerKey[]
  forms             Form[]             @relation("UserForms")
  formOwnerKeys     FormOwnerKey[]
  formSubmissions   FormSubmission[]   @relation("SubmitterFormSubmissions")
  subscriptions     Subscription[]
  deletionRequest   DeletionRequest?
  oauthApplications OauthApplication[]

  // Organizations (B2B multi-tenancy)
  memberships            Member[]
  sentInvitations        Invitation[]            @relation("SentInvitations")
  organizationMemberKeys OrganizationMemberKey[]

  twoFactorEnabled Boolean    @default(false)
  twoFactor        TwoFactor?
  // Quotas & Limits
  storageUsed      BigInt     @default(0)
  storageLimit     BigInt     @default(5368709120) // 5GB default for free users

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Access Control & Moderation
  isAdmin Boolean @default(false)

  // Ban System
  // We use granular flags rather than a single 'banned' state to allow
  // partial restrictions (e.g. stopping new uploads but allowing downloads).
  banned           Boolean @default(false)
  banAliasCreation Boolean @default(false)
  banFileUpload    Boolean @default(false)
  banReason        String?
  tosViolations    Int     @default(0)

  // Billing Downgrade Tracking
  downgradedAt DateTime? @map("downgraded_at")

  // Payment Method
  paymentMethod  String          @default("stripe") @map("payment_method")
  cryptoPayments CryptoPayment[]

  // Email preferences
  // One-click unsubscribe flag for growth emails (drip + power-user upsell).
  // Transactional emails (billing, auth, abuse) ignore this flag.
  dripUnsubscribed Boolean @default(false) @map("drip_unsubscribed")

  // Referrals
  // referralCode is generated lazily on first visit to the invite UI.
  // referredByUserId is set once, when a referred user is verified + claims.
  // referralPlusUntil grants complimentary Plus and is deliberately kept OUT of
  // the Subscription table so it never collides with Stripe/crypto reconciliation
  // or "is this a paying customer?" checks (checkout guard, billing portal, etc.).
  referralCode      String?   @unique @map("referral_code")
  referredByUserId  String?   @map("referred_by_user_id")
  referredBy        User?     @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals         User[]    @relation("UserReferrals")
  referralPlusUntil DateTime? @map("referral_plus_until")
  referralClaimedAt DateTime? @map("referral_claimed_at")

  @@index([referredByUserId])
  @@map("users")
}

model UserSecurity {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authSalt                  String
  vaultSalt                 String
  passwordWrappedVaultKey   String   @map("password_wrapped_vault_key")
  kdfVersion                Int      @default(1) @map("kdf_version")
  vaultGeneration           Int      @default(1) @map("vault_generation")
  passwordSetAt             DateTime @default(now()) @map("password_set_at")
  migrationState            String   @default("complete") @map("migration_state")
  // Org shared-E2EE identity keypair (see lib/vault/ORG-E2EE-DESIGN.md §3a):
  // public key plaintext; private key wrapped to the vault key; generation = the
  // vaultGeneration at wrap time, so a stale wrap after rotation is detectable.
  identityPublicKey         String?  @map("identity_public_key")
  wrappedIdentityPrivateKey String?  @map("wrapped_identity_private_key")
  identityKeyGeneration     Int?     @map("identity_key_generation")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("user_security")
}

model DropOwnerKey {
  id               String   @id @default(cuid())
  // Nullable + SetNull: for an ORG-owned owner key (organizationId set), the
  // wrappedKey is sealed to the org vault key and is the ONLY copy — it must
  // survive the creating user's deletion or the org drop becomes undecryptable.
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  dropId           String   @unique
  drop             Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  wrappedKey       String   @map("wrapped_key")
  vaultGeneration  Int      @map("vault_generation")
  // Org shared-E2EE: when organizationId is set, wrappedKey is wrapped to the org
  // vault key (not one user's vault key); orgKeyGeneration tracks the org key
  // generation to detect stale wraps after rotation (ORG-E2EE-DESIGN.md §4).
  organizationId   String?  @map("organization_id")
  orgKeyGeneration Int?     @map("org_key_generation")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("drop_owner_keys")
}

model Alias {
  id        String @id @default(cuid())
  email     String @unique // Full email address (localPart@domain)
  localPart String
  domain    String

  active Boolean @default(true)
  format String  @default("CUSTOM") // CUSTOM or RANDOM

  // Metadata
  legacyLabel    String? @map("label")
  legacyNote     String? @map("note")
  encryptedLabel String? @map("encrypted_label") @db.Text
  encryptedNote  String? @map("encrypted_note") @db.Text

  // Usage Telemetry
  emailsReceived Int       @default(0)
  emailsBlocked  Int       @default(0)
  lastEmailAt    DateTime?

  // Nullable + SetNull so deleting the creating user does NOT cascade-delete an
  // org-owned alias (owned by organizationId). A null userId on an org row means
  // "creator account was deleted"; the org still owns it.
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Forwarding Configuration — legacy single-recipient (kept for migration)
  recipientId String?
  recipient   Recipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  // Multi-recipient routing via join table
  aliasRecipients AliasRecipient[]

  // Legacy form notification relation retained for existing rows.
  formsNotified Form[] @relation("FormNotifyAlias")

  scheduledForRemovalAt DateTime? @map("scheduled_for_removal_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, active])
  @@index([userId, legacyLabel], map: "aliases_userId_label_idx")
  @@index([recipientId])
  @@index([scheduledForRemovalAt])
  @@index([organizationId])
  @@map("aliases")
}

model Recipient {
  id        String  @id @default(cuid())
  email     String
  verified  Boolean @default(false)
  isDefault Boolean @default(false)

  // Verification
  verificationToken  String?   @unique
  verificationExpiry DateTime?

  // PGP Integration
  // Users can provide their public key to have forwarded emails encrypted.
  pgpPublicKey   String? @db.Text
  pgpFingerprint String?
  pgpKeyName     String?

  // Nullable + SetNull so deleting the creating user keeps an org-owned recipient
  // (owned by organizationId) instead of cascade-deleting it.
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Legacy direct relation (kept for migration)
  aliases Alias[]

  // Multi-recipient routing via join table
  aliasRecipients AliasRecipient[]

  scheduledForRemovalAt DateTime? @map("scheduled_for_removal_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Scope-aware uniqueness: an email is unique within an owner scope. Personal
  // recipients (organizationId = null) and org recipients are separate spaces,
  // so the same user can forward to the same address both personally and in an
  // org. NULLS DISTINCT means personal dupes aren't DB-enforced here — that
  // invariant is upheld at the app layer (serializable scope check in
  // RecipientService.addRecipient).
  @@unique([userId, organizationId, email])
  @@index([userId])
  @@index([verificationToken])
  @@index([scheduledForRemovalAt])
  @@index([organizationId])
  @@map("recipients")
}

model AliasRecipient {
  id          String    @id @default(cuid())
  aliasId     String
  alias       Alias     @relation(fields: [aliasId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  ordinal   Int     @default(0) // Ordering: 0 = first/primary
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([aliasId, recipientId])
  @@index([aliasId])
  @@index([recipientId])
  @@map("alias_recipients")
}

model Domain {
  id                String  @id @default(cuid())
  domain            String
  verified          Boolean @default(false)
  ownershipVerified Boolean @default(false)
  mxVerified        Boolean @default(false)
  spfVerified       Boolean @default(false)
  dnsVerified       Boolean @default(false)
  verificationToken String  @default(cuid())

  // DKIM Support for better deliverability on custom domains
  dkimPrivateKey String? @db.Text
  dkimPublicKey  String? @db.Text
  dkimSelector   String? @default("default")
  dkimVerified   Boolean @default(false)

  // Catch-all: auto-create aliases for any email received on this domain
  catchAll            Boolean @default(false) @map("catch_all")
  catchAllRecipientId String? @map("catch_all_recipient_id")

  userId String?
  // SetNull (not Cascade): org-owned domains also carry the creating member's
  // userId, so deleting that member must keep the org's domain — only the
  // personal owner link is cleared. Matches the existing FK; explicit for clarity.
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  scheduledForRemovalAt DateTime? @map("scheduled_for_removal_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain])
  @@index([userId])
  @@index([scheduledForRemovalAt])
  @@index([organizationId])
  @@map("domains")
}

model ApiKey {
  id        String  @id @default(cuid())
  keyHash   String  @unique @map("key_hash") // SHA-256 hash
  keyPrefix String  @map("key_prefix")
  label     String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([organizationId])
  @@map("api_keys")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  idToken              String?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id                String   @id @default(cuid())
  token             String   @unique
  userId            String
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  twoFactorVerified Boolean  @default(false)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Active organization context (managed by the better-auth organization plugin)
  activeOrganizationId String?

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model DropFile {
  id            String @id
  encryptedName String
  storageKey    String
  size          BigInt
  mimeType      String

  // Encryption Metadata
  iv String

  // Multipart Upload Tracking
  s3UploadId     String?
  chunkCount     Int?
  chunkSize      Int?
  uploadComplete Boolean @default(false)

  // Relations
  dropId String
  drop   Drop   @relation(fields: [dropId], references: [id], onDelete: Cascade)

  chunks UploadChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dropId])
  @@index([s3UploadId])
  @@map("drop_files")
}

model Drop {
  id String @id

  // Encrypted Content Container
  encryptedTitle   String?
  encryptedMessage String?

  // Encryption Parameters
  iv            String
  customKey     Boolean @default(false)
  salt          String?
  customKeyData String? // Wrapped key
  customKeyIv   String?

  // Access Controls
  expiresAt    DateTime?
  maxDownloads Int?
  maxFileCount Int? // Maximum files allowed in this drop
  downloads    Int       @default(0)
  disabled     Boolean   @default(false)
  disabledAt   DateTime?

  // Customization
  hideBranding Boolean @default(false)

  // Notifications (Pro feature)
  notifyOnDownload  Boolean   @default(false)
  notificationsSent Int       @default(0)
  expiryNotifiedAt  DateTime?

  // Status tracking
  uploadComplete Boolean   @default(false)
  viewedAt       DateTime?

  // Lifecycle
  deletedAt DateTime? // Soft delete

  // Takedown
  takenDown      Boolean   @default(false)
  takedownReason String?
  takenDownAt    DateTime?

  // Relations
  files          DropFile[]
  uploadTokens   UploadToken[]
  ownerKey       DropOwnerKey?
  formSubmission FormSubmission? @relation("FormSubmissionDrop")
  userId         String?
  // SetNull (not Cascade) so deleting the creating user keeps an org-owned drop
  // (owned by organizationId). Personal drops have organizationId null and are
  // reaped by the explicit, org-scoped deletion in lib/services/deletion.ts.
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt, createdAt])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([uploadComplete])
  @@index([maxDownloads])
  @@index([organizationId])
  @@map("drops")
}

model UploadToken {
  id String @id @default(cuid())

  dropId String
  drop   Drop   @relation(fields: [dropId], references: [id], onDelete: Cascade)

  // Optional form binding: when set, this token was issued by a form submission
  // flow so guests can upload larger files than the 100MB guest cap while the
  // storage is billed to the form creator.
  formId String?
  form   Form?   @relation(fields: [formId], references: [id], onDelete: Cascade)

  tokenHash String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@unique([tokenHash])
  @@index([dropId])
  @@index([formId])
  @@index([expiresAt])
  @@map("upload_tokens")
}

model UploadChunk {
  id     String   @id @default(cuid())
  fileId String
  file   DropFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  chunkIndex Int
  etag       String?
  size       BigInt
  completed  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileId, chunkIndex])
  @@index([fileId])
  @@map("upload_chunks")
}

// ─── Forms ──────────────────────────────────────────────────────────────────
// Form submissions are end-to-end encrypted using a per-form X25519 keypair.
// The public key is served with the form so each submitter encrypts with
// ECDH+AES-GCM; only the creator can decrypt. Title/description/schemaJson are
// intentionally plaintext — they are the questions the public needs to see.
model Form {
  id String @id // 12-char alphanumeric public id

  // Nullable + SetNull so deleting the creating user keeps an org-owned form
  // (owned by organizationId) instead of cascade-deleting it and its submissions.
  userId String?
  user   User?  @relation("UserForms", fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Authoring (plaintext — these are public to anyone with the form link)
  title       String
  description String? @db.Text
  schemaJson  String  @db.Text

  // Per-form X25519 public key (base64url). Private key is vault-wrapped in FormOwnerKey.
  publicKey String

  // Behavior
  active            Boolean   @default(true)
  disabledByUser    Boolean   @default(false)
  customKey         Boolean   @default(false) // password-protect viewing/submitting
  salt              String?
  customKeyData     String?
  customKeyIv       String?
  customKeyVerifier String?   @map("custom_key_verifier")
  maxSubmissions    Int?
  closesAt          DateTime?
  hideBranding      Boolean   @default(false) // Pro only

  // File uploads
  allowFileUploads    Boolean @default(false)
  maxFileSizeOverride BigInt?

  // Submission notifications. Alias routing is legacy; notifications now go to the account email.
  notifyAliasId       String?
  notifyAlias         Alias?  @relation("FormNotifyAlias", fields: [notifyAliasId], references: [id], onDelete: SetNull)
  notifyEmailFallback Boolean @default(true)

  // Counters
  submissionsCount Int @default(0)

  // Moderation
  takenDown      Boolean   @default(false)
  takedownReason String?
  takenDownAt    DateTime?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions  FormSubmission[]
  ownerKey     FormOwnerKey?
  uploadTokens UploadToken[]

  @@index([userId])
  @@index([userId, deletedAt, createdAt])
  @@index([closesAt])
  @@index([notifyAliasId])
  @@index([organizationId])
  @@map("forms")
}

// Mirror of DropOwnerKey: vault-wrapped X25519 private key.
model FormOwnerKey {
  id               String   @id @default(cuid())
  // Nullable + SetNull: an org-owned owner key (organizationId set) is the only
  // copy of the form key sealed to the org vault key — it must survive the
  // creating user's deletion or the org form's submissions become undecryptable.
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  formId           String   @unique
  form             Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  wrappedKey       String   @map("wrapped_key") @db.Text
  vaultGeneration  Int      @map("vault_generation")
  // Org shared-E2EE: when organizationId is set, wrappedKey is wrapped to the org
  // vault key (not one user's vault key); orgKeyGeneration tracks the org key
  // generation to detect stale wraps after rotation (ORG-E2EE-DESIGN.md §4).
  organizationId   String?  @map("organization_id")
  orgKeyGeneration Int?     @map("org_key_generation")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("form_owner_keys")
}

model FormSubmission {
  id     String @id // 14-char alphanumeric
  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  // Ciphertext — decryptable only by creator (vault-unwrap → ECDH → AES-GCM)
  ephemeralPubKey  String
  iv               String
  encryptedPayload String @db.Text

  // Optional attached drop (files). The drop is owned by the form creator and
  // the E2EE symmetric key is carried inside encryptedPayload so only the
  // creator can open it.
  attachedDropId String? @unique
  attachedDrop   Drop?   @relation("FormSubmissionDrop", fields: [attachedDropId], references: [id], onDelete: SetNull)

  submitterUserId String?
  submitter       User?     @relation("SubmitterFormSubmissions", fields: [submitterUserId], references: [id], onDelete: SetNull)
  submitterIpHash String?
  readAt          DateTime?

  createdAt DateTime @default(now())

  @@index([formId, createdAt])
  @@index([submitterUserId])
  @@map("form_submissions")
}

model TwoFactor {
  id          String  @id @default(cuid())
  userId      String  @unique
  secret      String
  backupCodes String
  verified    Boolean @default(false)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factors")
}

model AbuseReport {
  id String @id @default(cuid())

  serviceType String // "alias" or "drop"
  resourceId  String
  reason      String
  description String @db.Text
  priority    String @default("normal") // urgent, high, normal, low

  contactEmail           String?
  decryptionKey          String?
  decryptionKeyEncrypted Boolean @default(false)

  trackingToken String? @unique

  reporterIp String

  status      String    @default("pending")
  reviewNotes String?   @db.Text
  reviewedAt  DateTime?
  reviewedBy  String?

  actionTaken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([resourceId])
  @@index([serviceType])
  @@index([createdAt])
  @@index([reporterIp])
  @@index([updatedAt])
  @@index([priority, createdAt])
  @@map("abuse_reports")
}

model CryptoPayment {
  id            String    @id @default(cuid())
  nowPaymentId  String    @unique @map("now_payment_id")
  invoiceId     String?   @unique @map("invoice_id")
  orderId       String    @unique @map("order_id")
  payAmount     Float     @map("pay_amount")
  payCurrency   String    @map("pay_currency")
  priceAmount   Float     @map("price_amount")
  priceCurrency String    @default("usd") @map("price_currency")
  actuallyPaid  Float?    @map("actually_paid")
  product       String
  tier          String
  planPriceId   String    @map("stripe_price_id")
  status        String    @default("waiting")
  periodStart   DateTime? @map("period_start")
  periodEnd     DateTime? @map("period_end")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("crypto_payments")
}

model Subscription {
  id String @id @default(cuid())

  // Nullable + SetNull so deleting the buyer's account does NOT cascade-delete an
  // org-owned Business subscription (it belongs to the org, not the user). The
  // org link is the source of truth for org subs; userId is the buyer/billing
  // contact and may be null after the buyer's account is deleted.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Payment provider
  provider               String // "stripe" | "crypto" | "manual"
  providerSubscriptionId String? @unique @map("provider_subscription_id")
  providerCustomerId     String? @map("provider_customer_id")
  providerPriceId        String? @map("provider_price_id")

  // Plan details
  product String // "bundle" | "alias" | "drop" | "form" | "business"
  tier    String // "plus" | "pro"
  seats   Int    @default(1) // per-seat quantity (org/business subscriptions)

  // Status & billing period
  status             String // "active" | "trialing" | "past_due" | "canceled" | "expired"
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerCustomerId])
  @@index([organizationId])
  @@map("subscriptions")
}

model DeletionRequest {
  id     String @id @default(cuid())
  userId String @unique
  // Restrict: the deletion flow removes this row before deleting the user row
  // (see lib/services/deletion.ts), so the user can't be hard-deleted while a
  // request is still mid-process. Matches the existing FK; explicit for clarity.
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  status String // "pending" | "active_systems_deleted"

  // Per-resource progress tracking
  sessionsDeleted Boolean @default(false)
  aliasesDeleted  Boolean @default(false)
  domainsDeleted  Boolean @default(false)
  formsDeleted    Boolean @default(false)
  dropsDeleted    Boolean @default(false)
  storageDeleted  Boolean @default(false)

  failedStorageKeys String? @db.Text // JSON array of S3 keys that failed deletion

  requestedAt DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([requestedAt])
  @@map("deletion_requests")
}

model ReservedAlias {
  id        String   @id @default(cuid())
  alias     String   @unique
  createdAt DateTime @default(now())

  @@map("reserved_aliases")
}

model OrphanedFile {
  id         String   @id @default(cuid())
  storageKey String
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("orphaned_files")
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String // e.g. "api_key.create", "drop.takedown", "user.ban", "admin.login"
  actorId        String // User who performed the action
  targetId       String? // Affected resource ID (user, alias, drop, etc.)
  // Set for org-scoped events (org.member.add, org.vault.grant, …) so org admins
  // can view their own org's audit trail without seeing the platform-wide log.
  organizationId String?  @map("organization_id")
  metadata       String?  @db.Text // JSON-encoded extra context
  ip             String?
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@index([organizationId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Organizations (B2B multi-tenancy) ──────────────────────────────────────
// Managed by better-auth's organization plugin (v1.6.14). Field names/types
// match the plugin's expected schema; columns stay camelCase like the other
// better-auth tables (sessions/accounts). Org-owned resources carry a nullable
// organizationId — a null organizationId means the resource is personal.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Org-wide security policy (enforced via lib/access-policy.ts)
  enforce2FA Boolean @default(false)

  // Shared-team E2EE coordination (ORG-E2EE-DESIGN.md). `orgKeyGeneration` is the
  // authoritative org vault key generation: 0 = unseeded, bumped to 1 on seed and
  // +1 on each rotation. Seed/rotate use a conditional update on this column as a
  // single-winner lock; "stale member key" = OrganizationMemberKey.orgKeyGeneration
  // < this. `keyRotationRecommendedAt` is set when a member is removed (soft
  // revocation) and cleared on rotation, so the team-page banner survives refresh.
  orgKeyGeneration         Int       @default(0) @map("org_key_generation")
  keyRotationRecommendedAt DateTime? @map("key_rotation_recommended_at")

  // Plugin relations
  members     Member[]
  invitations Invitation[]
  memberKeys  OrganizationMemberKey[]

  // Org-owned resources
  aliases       Alias[]
  recipients    Recipient[]
  domains       Domain[]
  drops         Drop[]
  forms         Form[]
  apiKeys       ApiKey[]
  subscriptions Subscription[]

  @@map("organizations")
}

/// Org shared-E2EE: the org vault key, wrapped to each member's identity public
/// key (ORG-E2EE-DESIGN.md §3b). One row per (org, member); never stores the
/// plaintext org vault key. Cascades on org or user deletion.
model OrganizationMemberKey {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wrappedOrgVaultKey String       @map("wrapped_org_vault_key") @db.Text
  orgKeyGeneration   Int          @default(1) @map("org_key_generation")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_member_keys")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member") // owner | admin | member (see lib/auth-permissions.ts)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending") // pending | accepted | rejected | canceled
  inviterId      String
  inviter        User         @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// OAuth 2.0 / OIDC tables consumed by better-auth's MCP plugin.
// Field names are dictated by the plugin schema; do not rename.
model OauthApplication {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientSecret String?
  type         String // "public" | "web" | "native" | "user-agent-based"
  name         String
  icon         String?
  metadata     String?  @db.Text
  redirectUrls String   @db.Text
  disabled     Boolean  @default(false)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("oauth_applications")
}

model OauthAccessToken {
  id                    String   @id @default(cuid())
  accessToken           String   @unique
  refreshToken          String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  clientId              String
  userId                String
  scopes                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauth_access_tokens")
}

model OauthConsent {
  id           String   @id @default(cuid())
  clientId     String
  userId       String
  scopes       String
  consentGiven Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clientId, userId])
  @@map("oauth_consents")
}
